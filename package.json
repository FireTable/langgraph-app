{
  "name": "langgraph-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k --kill-signal=SIGTERM -n frontend,backend -c cyan,magenta \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:stop": "lsof -ti :2024,:3000 2>/dev/null | xargs -r kill -TERM; sleep 1; lsof -ti :2024,:3000 2>/dev/null | xargs -r kill -KILL; true",
    "dev:frontend": "next dev --turbopack",
    "dev:backend": "langgraphjs dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint --type-aware --type-check && oxfmt --check",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint:fix": "oxlint --type-aware --type-check --fix && oxfmt",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:reset": "drizzle-kit drop",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.26",
    "@assistant-ui/react-langgraph": "^0.14.11",
    "@assistant-ui/react-markdown": "^0.14.5",
    "@assistant-ui/react-o11y": "^0.0.25",
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@base-ui/react": "^1.6.0",
    "@better-auth-ui/core": "^1.6.27",
    "@better-auth-ui/react": "^1.6.27",
    "@deno/sandbox": "^0.13.2",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@langchain/langgraph-sdk": "^1.9.25",
    "@langchain/openai": "^1.5.3",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.2",
    "assistant-stream": "^0.3.25",
    "better-auth": "^1.6.23",
    "bowser": "^2.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "immutable-json-patch": "^6.0.3",
    "lru-cache": "^11.5.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "prism-react-renderer": "^2.4.1",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.6",
    "remark-gfm": "^4.0.1",
    "resend": "^6.17.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.11",
    "ufo": "^1.6.4",
    "viem": "^2.54.3",
    "wagmi": "2.19.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@assistant-ui/next": "latest",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph-cli": "^1.4.1",
    "@next/env": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "oxfmt",
    "*.{ts,tsx}": "oxlint --type-aware --type-check --fix"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.16.1",
  "pnpm": {
    "overrides": {
      "qr": "0.5.5"
    },
    "patchedDependencies": {
      "@assistant-ui/core@0.2.20": "patches/@assistant-ui__core@0.2.20.patch"
    }
  }
}
