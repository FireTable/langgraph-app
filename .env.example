# Backend (LangGraph server) — provider is OpenAI-compatible.
OPENAI_API_KEY=
# Optional override; defaults to gpt-4o-mini
OPENAI_MODEL=
# Optional. Override the upstream base URL when pointing at an
# OpenAI-compatible endpoint (Azure, local proxy, third-party gateway, ...).
# Leave unset to use the default https://api.openai.com/v1.
OPENAI_BASE_URL=

# LangSmith tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=assistant-ui-with-langgraph-template

# Frontend (Next.js proxy to LangGraph)
LANGGRAPH_API_URL=http://localhost:2024
# Forwarded as `x-api-key`. Leave blank for local dev.
LANGCHAIN_API_KEY=
# Graph id. Must match a key under "graphs" in langgraph.json.
NEXT_PUBLIC_LANGGRAPH_ASSISTANT_ID=agent
# Optional. Bypasses the /api proxy and lets the browser hit LangGraph directly.
# Leave unset to route everything through the Next.js proxy on the current host.
NEXT_PUBLIC_LANGGRAPH_API_URL=

# Postgres — local dev: postgresql://USER@localhost:5432/DBNAME (no password).
# Production: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
# Test database URL — used by `pnpm test` (vitest + NODE_ENV=test reads .env.test).
DATABASE_URL_TEST=

# Better Auth (required) — 32-byte hex secret for cookie signing.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Base URL of the Next.js app. Used for OAuth callback URL construction.
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Graph topology toggle — "true" uses compiled weatherAgent/chatAgent
# subgraphs; unset / any other value uses the inlined version (default,
# works around the @langchain/core 1.2.1 EventStreamCallbackHandler
# "Run ID not found in run map" bug). See memory/langgraph-subgraph-run-map-bug.md.
# Backend reads USE_SUBGRAPH; the frontend reads NEXT_PUBLIC_USE_SUBGRAPH.
USE_SUBGRAPH=
NEXT_PUBLIC_USE_SUBGRAPH=

# Google OAuth Client — https://console.cloud.google.com/apis/credentials
# Callback URL: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — https://resend.com/api-keys (free tier: 100 emails/day).
# Sender domain must be verified in production; dev can use onboarding@resend.dev.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Jina AI — https://jina.ai/reader (used by web-search + web-fetch tools).
# Comma-separated API keys. The pool picks one at random per request;
# 401/403 responses remove that key from the pool and retry.
# Get free keys at https://jina.ai/reader after sign-up.
JINA_API_KEYS=