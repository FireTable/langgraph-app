# Deploy-only variables — not read by the app (Next.js / LangGraph).
# Only consumed by docker-compose.yml + the `caddy` container. Skip
# these for Mac-local `pnpm dev`; set them when deploying per
# docs/DEPLOY.md.
#
# Image tag (see docs/CI.md § Tag strategy — main → :latest, dev → :beta-<sha>).
# REQUIRED for `docker compose up`: `app:` service uses `image: ${IMAGE}`
# and `build:` together. VPS: set to `ghcr.io/<owner>/langgraph-app:latest`
# (so `docker compose pull app && docker compose up -d` uses the GHCR
# image, never builds from source). Local dev: set to `langgraph-app`
# (local tag — `docker compose up` builds from source on first run,
# reuses the cached image afterwards).
IMAGE=
# Public domain Caddy should serve. Becomes the `{$CADDY_DOMAIN}` host
# in the Caddyfile; Caddy substitutes it at startup. Required for the
# `caddy` service — compose errors out if missing.
CADDY_DOMAIN=
# Postgres service credentials (compose reads these to provision the
# `postgres` container; the `app` container's DATABASE_URL is built from
# them via ${VAR} substitution in compose's environment: block).
POSTGRES_USER=
POSTGRES_PASSWORD=           # generate with: openssl rand -hex 24
POSTGRES_DB=

# Backend (LangGraph server) — provider is OpenAI-compatible.
OPENAI_API_KEY=
# Optional override; defaults to gpt-4o-mini
OPENAI_MODEL=
# Optional. Override the upstream base URL when pointing at an
# OpenAI-compatible endpoint (Azure, local proxy, third-party gateway, ...).
# Leave unset to use the default https://api.openai.com/v1.
OPENAI_BASE_URL=

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Public site URL — used by app/robots.ts, app/sitemap.ts, and
# app/(landing)/layout.tsx (metadataBase + OG image). Server-only.
# Leave unset to fall back to the ai.firetable.tech default.
SITE_URL=

# Frontend (Next.js proxy to LangGraph)
LANGGRAPH_API_URL=http://localhost:2024
# Forwarded as `x-api-key`. Leave blank for local dev.
LANGCHAIN_API_KEY=
# Graph id. Must match a key under "graphs" in langgraph.json.
LANGGRAPH_ASSISTANT_ID=agent
# Optional. Bypasses the /api proxy and lets the browser hit LangGraph
# directly (e.g. behind Cloudflare Tunnel). Leave unset to route
# everything through the Next.js proxy on the current host. Read in
# the browser via window.__CONFIG__.
# Distinct from the server-side LANGGRAPH_API_URL above so deploys where
# the proxy destination and the public browser URL diverge (tunnels,
# split domains) keep both knobs.
LANGGRAPH_PUBLIC_URL=

# Postgres — local dev: postgresql://USER@localhost:5432/DBNAME (no password).
# Production: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
# Test database URL — used by `pnpm test` (vitest + NODE_ENV=test reads .env.test).
DATABASE_URL_TEST=

# Better Auth (required) — 32-byte hex secret for cookie signing.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Base URL of the Next.js app. Used for OAuth callback URL construction.
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth Client — https://console.cloud.google.com/apis/credentials
# Callback URL: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — https://resend.com/api-keys (free tier: 100 emails/day).
# Sender domain must be verified in production; dev can use onboarding@resend.dev.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Jina AI — https://jina.ai/reader
# Comma-separated API keys. The pool picks one at random per request;
# 401/403 responses remove that key from the pool and retry.
# Get free keys at https://jina.ai/reader after sign-up.
# - REQUIRED for the `search_web` tool (s.jina.ai returns 401 without auth).
#   The tool is not registered in the agent's list when this is empty.
# - OPTIONAL for the `fetch_url` tool — r.jina.ai accepts unauthenticated
#   requests on the free tier (lower rate limit). A key just lifts the
#   limit; absence does NOT disable the tool.
JINA_API_KEYS=

# Alchemy RPC — https://dashboard.alchemy.com/
# Server-only. Used by app/api/alchemy/[...path] to proxy JSON-RPC
# requests (browser-side wallet portfolio view) AND by the
# `get_NFT_holdings` crypto tool (server-side Alchemy NFT API call).
# When unset, `get_NFT_holdings` is not registered in the agent's
# tool list (the model just doesn't see it); the JSON-RPC proxy
# stays up but returns 401 on every request.
# Never reaches the browser.
ALCHEMY_API_KEY=
# Optional. Comma-separated Alchemy network slugs the proxy will REJECT
# (turn-off list). The proxy accepts every network in the static catalog
# (lib/alchemy/networks.ts) by default — set this to disable specific
# chains in production (e.g. testnets). Leave empty to enable all.
ALCHEMY_DISABLED_NETWORKS=

# WalletConnect / Reown projectId — https://dashboard.reown.com
# Bundled into the browser (via window.__CONFIG__ in app/layout.tsx) on
# purpose: it's a public dapp identifier, not a secret (Reown docs:
# "this is a public identifier"). The free tier covers 100k connections
# / month. Required for WalletConnect-based wallets (binanceWallet,
# bitgetWallet) to expose their mobile-QR fallback; injected wallets
# (MetaMask, Coinbase, Rainbow, Safe) work without it.
WALLET_CONNECT_PROJECT_ID=

# Deno Deploy — https://console.deno.com/
# Server-only. Used by the code agent's `execute_code` tool via the
# @deno/sandbox SDK to run untrusted code in a Firecracker microVM.
# Supported languages: TypeScript / JavaScript (Deno `eval`) and
# Python (`python3 -c`, stdlib only — sandbox image ships CPython 3.13).
# Create an access token at
# https://console.deno.com/ → Sandbox tab → access tokens.
#   - If you create an ORGANIZATION token (starts with ddo_*), you only
#     need DENO_DEPLOY_TOKEN.
#   - If you create a PERSONAL token (starts with ddp_*), you also need
#     DENO_DEPLOY_ORG — your org slug from the console URL.
# When unset, `execute_code` is not registered in the agent's tool
# list — the model can still propose code via `write_code`, and on
# Run the model surfaces a graceful fallback. Free tier: 1M requests
# / 15h CPU / month — see https://deno.com/deploy/pricing.
DENO_DEPLOY_TOKEN=
DENO_DEPLOY_ORG=

# Cloudflare R2 — https://dash.cloudflare.com/?to=/:account/r2
# Server-only. Backs chat attachments (issue #12, design at
# docs/ATTACHMENTS.md). 5 required vars + 2 optional.
# Create an API token at dash.cloudflare.com → R2 → "Manage R2 API
# Tokens" → "Create API token" with Object Read & Write scoped to
# the bucket. R2_ACCOUNT_ID is the account id from the R2 dashboard URL.
# When any of R2_ACCOUNT_ID / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY /
# R2_BUCKET / R2_PUBLIC_BASE_URL is unset, every route under
# /api/attachments/* returns 503 with
# `{ "error": "attachments_not_configured", "message": ... }`.
# Mirrors the DENO_DEPLOY_TOKEN / ALCHEMY_API_KEY lazy-register
# pattern. The bucket also needs a CORS rule allowing PUT from
# <YOUR_PUBLIC_DOMAIN> — see docs/ATTACHMENTS.md.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
# Optional. Per-file size cap in bytes; default 10485760 (10 MiB).
R2_MAX_BYTES=10485760
# Optional. Comma-separated MIME allow-list; default png/jpeg/webp only.
# PDF (and other non-image types) is intentionally excluded — PDF
# ingestion moved to the knowledge base (#13) which will own all
# derived representations. The chat composer no longer surfaces a PDF
# picker until KB lands. Override here to re-enable a non-image flow
# in the meantime.
#
# The presign route rejects anything not in this list. Read by both
# `app/api/attachments/presign/route.ts` (server-side rejection) AND by
# `R2AttachmentAdapter.accept` (composer file-picker filter) — single
# source of truth, no client/server drift. Safe to expose: the value
# is public config, not a secret. The browser-side read goes through
# window.__CONFIG__ (see app/layout.tsx).
R2_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/webp
# Attachments feature toggle — gates the assistant-ui `<Composer />`
# attachment UI AND the Settings → Account avatar upload (both backed by
# R2). Default false; flip to "true" once every required R2_* above is
# set. Frontend and backend must be in sync: if this stays "false" the
# composer hides the attachment widget + the avatar upload is disabled,
# but routes still answer when called. Read in browser via window.__CONFIG__.
ATTACHMENTS_ENABLED=false


# Observability — how long CapturedSpan rows are kept before retention
# deletes them. Must be a positive integer. Default 30 days.
OBSERVABILITY_RETENTION_DAYS=30

# Memory (LangGraph long-term store). Read once at module load (NFR-004).
# Missing / empty / non-numeric values fall back to the defaults below.
#   KEEP_RECENT — single knob for thread summarization. Controls all
#     three at once: BATCH SIZE per compress pass (KEEP_RECENT human
#     turns), TRIGGER CADENCE (fires every KEEP_RECENT new turns), and
#     RECENT FLOOR (the last KEEP_RECENT turns are never compressed).
#     Default 10. Must be a non-negative integer.
#   PROFILE_MAX_BYTES — hard cap on serialized profile doc size. save_memory
#     rejects patches that would push the doc over this limit.
#     Default 8192.
MEMORY_THREAD_SUMMARY_KEEP_RECENT=10
MEMORY_PROFILE_MAX_BYTES=8192

# Provider encryption KEK — AES-256-GCM key that wraps every entry in
# `provider.apiKeys[].encryptedKey`. REQUIRED to start the server; the
# admin UI returns 503 on first request if this is missing or malformed
# (we refuse to silently fall back to "no encryption" mode).
# Generate once with: openssl rand -hex 32
# Set-and-forget: rotating it is out of scope for this project (would
# require a one-shot re-encryption script over every row in provider.apiKeys).
LLM_KEY_ENCRYPTION_KEY=

# Bootstrap admin email. On signup, if the user's email matches this value
# (case-insensitive), their role_id is set to 'admin'. Idempotent — leave
# set forever; only the FIRST signup with this email is promoted. To add
# a second admin later, use the admin UI role management tab.
INITIAL_ADMIN_EMAIL=

# KB retrieval knobs (issue #13 v3). All server-only — backend tool
# surface and mention resolver read these via lib/kb/env.ts. Defaults
# reflect the community survey in `.claude/13-kb-v3.md`:
#   LangChain EnsembleRetriever / LlamaIndex QueryFusionRetriever /
#   Haystack DocumentJoiner — per-leg 50, fused 5–10; Mastra = 3;
#   Mastra + Vercel AI SDK RAG chunks = 512–1024 tokens.
#   KB_MENTION_TOPK_DEFAULT — chunks per single @-mention. 5.
#   KB_MENTION_TOPK_MAX     — per-mention upper bound when user overrides. 20.
#   KB_MENTION_TOKEN_BUDGET — total token cap across multi-mention turns.
#                             Per-mention topK is rebudgeted as
#                             ceil(BUDGET / (CHUNK_MAX_CHARS/4 * mentions)).
#                             8192.
#   KB_HYBRID_TOPK_DEFAULT  — fused topK for the search_kb tool. 8.
#   KB_HYBRID_TOPK_MAX      — fused topK upper bound for the tool. 20.
#   KB_CHUNK_MAX_CHARS      — per-chunk truncation before stuffing into
#                             the LLM prompt; ~512 tokens at 4 chars/token.
#                             2000.
KB_MENTION_TOPK_DEFAULT=5
KB_MENTION_TOPK_MAX=20
KB_MENTION_TOKEN_BUDGET=8192
KB_HYBRID_TOPK_DEFAULT=8
KB_HYBRID_TOPK_MAX=20
KB_CHUNK_MAX_CHARS=2000